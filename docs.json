{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Intervimo",
  "description": "Documentation officielle Intervimo pour les locataires, gestionnaires et prestataires.",
  "colors": {
    "primary": "#FD593E",
    "light": "#FF8A70",
    "dark": "#E64A30"
  },
  "favicon": "/favicon.png",
  "appearance": {
    "default": "system"
  },
  "background": {
    "color": {
      "light": "#F3F1ED",
      "dark": "#0E0D0B"
    }
  },
  "styling": {
    "eyebrows": "breadcrumbs"
  },
  "icons": {
    "library": "lucide"
  },
  "search": {
    "prompt": "Rechercher dans la documentation Intervimo..."
  },
  "navigation": {
    "pages": [
      {
        "group": "Concepts",
        "pages": [
          "concepts/cycle-de-vie",
          "concepts/roles-acteurs",
          "concepts/glossaire",
          "concepts/prise-en-main"
        ]
      },
      {
        "group": "Locataires",
        "pages": [
          "locataires/signaler",
          "locataires/suivre"
        ]
      },
      {
        "group": "Gestionnaires",
        "pages": [
          "gestionnaires/qualifier",
          "gestionnaires/matchmaking",
          "gestionnaires/devis",
          "gestionnaires/planification"
        ]
      },
      {
        "group": "Prestataires",
        "pages": [
          "prestataires/recevoir-chiffrer",
          "prestataires/executer"
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/intervimo_wordmark.png",
    "dark": "/logo/intervimo_wordmark.png",
    "href": "/"
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  }
}
